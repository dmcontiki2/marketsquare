# MarketSquare nightly backup — configuration
# Copy to /etc/marketsquare-backup.env on the server, fill in, then: chmod 600 /etc/marketsquare-backup.env
# NOTHING in here should ever be committed to git. (ops/backup/.gitignore already blocks backup.env)

# ---- What to back up (adjust to your real server paths) ----
APP_DIR="/var/www/marketsquare"                      # FastAPI app + html/js/css
SQLITE_DB="/var/www/marketsquare/marketsquare.db"    # <-- set to the REAL SQLite file path
MEDIA_DIR="/var/www/marketsquare/media"              # uploaded images etc.
REDIS_RDB="/var/lib/redis/dump.rdb"                  # Redis snapshot (BGSAVE writes here)
# Extra config files/dirs to include (space-separated, optional):
EXTRA_PATHS="/etc/nginx/sites-enabled /etc/systemd/system/marketsquare.service"
# n8n data dir if self-hosted (optional, else leave empty):
N8N_DIR=""

# ---- Local staging + tier-1 backup (the extra 100GB drive) ----
STAGE_DIR="/var/backups/marketsquare/stage"          # scratch; cleared each run
LOCAL_RESTIC_REPO="/mnt/backup100/restic-marketsquare"   # <-- mount point of the 100GB drive

# ---- Tier-2 off-server backup (Hetzner Storage Box, SFTP) ----
# Storage Box gives you e.g. u123456.your-storagebox.de and user u123456.
# Enable SSH on the box (Storage Box web UI -> "SSH support"), add the server's SSH public key.
STORAGEBOX_RESTIC_REPO="sftp:u123456@u123456.your-storagebox.de:/restic-marketsquare"

# ---- Encryption password for BOTH restic repos (same password) ----
# Generate once: openssl rand -base64 32   — then store it somewhere safe OFFLINE too,
# because without it the backups cannot be restored.
RESTIC_PASSWORD="CHANGE-ME-long-random-string"

# ---- Retention ----
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# ---- Optional: healthcheck ping URL (healthchecks.io / Uptime Kuma). Leave empty to skip. ----
HEALTHCHECK_URL=""
