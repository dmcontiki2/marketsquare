# ──────────────────────────────────────────────────────────────────────────────
# MarketSquare / TrustSquare — Server Environment Variables
# Copy this file to /var/www/marketsquare/.env on the Hetzner server
# Then: systemctl restart marketsquare
# ──────────────────────────────────────────────────────────────────────────────

# ── Paystack ──────────────────────────────────────────────────────────────────
# Test mode:  sk_test_xxxxxxxxxxxxxxxxxxxx  (use during development)
# Live mode:  sk_live_xxxxxxxxxxxxxxxxxxxx  (use after Paystack business verification)
PAYSTACK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Webhook secret — from Paystack dashboard → Settings → API Keys & Webhooks
# Paystack generates this when you add the webhook URL. Copy it here exactly.
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# ── Anthropic (AI Coach) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Hetzner Object Storage (Cloudflare R2) ────────────────────────────────────
HETZNER_S3_ENDPOINT=https://YOUR_BUCKET.r2.cloudflarestorage.com
HETZNER_S3_BUCKET=marketsquare-media
HETZNER_S3_ACCESS_KEY=YOUR_R2_ACCESS_KEY
HETZNER_S3_SECRET_KEY=YOUR_R2_SECRET_KEY

# ── n8n Email Notifications ───────────────────────────────────────────────────
N8N_WEBHOOK_ACCEPT=http://localhost:5678/webhook/intro-accepted
N8N_WEBHOOK_DECLINE=http://localhost:5678/webhook/intro-declined
N8N_WEBHOOK_NEW_INTRO=http://localhost:5678/webhook/new-intro

# ── Misc ──────────────────────────────────────────────────────────────────────
GEONAMES_USERNAME=dmcontiki2
MS_VAPID_SUBJECT=mailto:dmcontiki2@gmail.com
